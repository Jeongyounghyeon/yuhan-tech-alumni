# .env.local 작성 시 이 파일을 참고한다.
# 실제 값은 절대 이 파일에 작성하지 않는다.

# ───────────────────────────────
# Database (Prisma + PostgreSQL)
# ───────────────────────────────
# 로컬 개발: docker compose로 띄운 PostgreSQL
# 프로덕션: 자체 서버 PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yuhan_alumni"

# ───────────────────────────────
# NextAuth v5
# ───────────────────────────────
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ───────────────────────────────
# Cloudflare R2 (이미지 스토리지)
# ───────────────────────────────
# 대시보드: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# R2 버킷에 연결된 퍼블릭 커스텀 도메인 (또는 r2.dev 서브도메인)
R2_PUBLIC_URL=""
